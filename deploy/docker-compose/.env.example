# ============================================================
# JustScan — docker-compose environment variables
# Copy this file to .env and fill in the values.
# ============================================================

# Password for PostgreSQL. Must also be set in backend-config.yaml → database.password
POSTGRES_PASSWORD=change-me-in-production

# URL of the backend API as seen from the USER'S BROWSER.
# For local deployments:  http://localhost:8080
# For remote deployments: http://YOUR_SERVER_IP:8080  (or your domain)
# NOTE: this value is baked into the frontend image at BUILD time.
#       Change it before running "docker compose up --build".
NEXT_PUBLIC_API_URL=http://localhost:8080

# Optional: change exposed host ports
# BACKEND_PORT=8080
# FRONTEND_PORT=3000
