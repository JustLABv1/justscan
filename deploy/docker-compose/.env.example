# ============================================================
# JustScan — docker-compose environment variables
# Copy this file to .env and fill in the values.
# ============================================================

# Password for PostgreSQL. Must also be set in backend-config.yaml → database.password
POSTGRES_PASSWORD=change-me-in-production

# Pin to a specific release tag (e.g. v1.2.3). Defaults to latest.
# JUSTSCAN_VERSION=latest

# Optional: change the host port nginx listens on (default 80)
# HTTP_PORT=80
